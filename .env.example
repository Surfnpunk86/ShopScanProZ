# Server
PORT=3000

# Google PageSpeed Insights API
# Get it at: https://console.cloud.google.com/ -> Enable "PageSpeed Insights API" -> Create API Key
PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# Shopify (optional - only needed if using /api/shopify endpoints)
# For a Custom App on a single store, generate an Admin API access token
# from the store's Admin > Settings > Apps and sales channels > Develop apps
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_themes,read_content
